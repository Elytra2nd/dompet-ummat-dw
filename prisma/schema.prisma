generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model dim_date {
  sk_date                                                     Int                   @id
  tanggal                                                     DateTime              @db.Date
  tahun                                                       Int?                  @db.SmallInt
  bulan                                                       Int?                  @db.TinyInt
  nama_bulan                                                  String?               @db.VarChar(20)
  kuartal                                                     Int?                  @db.TinyInt
  hari                                                        Int?                  @db.TinyInt
  nama_hari                                                   String?               @db.VarChar(20)
  tipe_hari                                                   dim_date_tipe_hari?
  fact_penyaluran_fact_penyaluran_sk_tgl_berkasTodim_date     fact_penyaluran[]     @relation("fact_penyaluran_sk_tgl_berkasTodim_date")
  fact_penyaluran_fact_penyaluran_sk_tgl_disalurkanTodim_date fact_penyaluran[]     @relation("fact_penyaluran_sk_tgl_disalurkanTodim_date")
  fact_skor_kelayakan                                         fact_skor_kelayakan[]
  fact_survey                                                 fact_survey[]
}

model dim_donatur {
  sk_donatur   Int               @id @default(autoincrement())
  id_donatur   String            @unique(map: "id_donatur") @db.VarChar(50)
  nama_lengkap String?           @db.VarChar(255)
  alamat       String?           @db.Text
  perusahaan   String?           @db.VarChar(255)
  tipe         dim_donatur_tipe?
  kontak_utama String?           @db.VarChar(100)
  valid_from   DateTime?         @default(dbgenerated("'2018-01-01'")) @db.Date
  valid_to     DateTime?         @default(dbgenerated("'9999-12-31'")) @db.Date
  is_active    Boolean?          @default(true)
  fact_donasi  fact_donasi[]
}

model dim_jalur_pembayaran {
  sk_jalur_pembayaran Int                                @id @default(autoincrement())
  metode_bayar        dim_jalur_pembayaran_metode_bayar?
  cara_donasi         String?                            @db.VarChar(100)
  bank_asal           String?                            @db.VarChar(100)
  kategori_bank       String?                            @db.VarChar(100)
  fact_donasi         fact_donasi[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model dim_lokasi {
  sk_lokasi              Int                      @id @default(autoincrement())
  provinsi               String?                  @default("Kalimantan Barat") @db.VarChar(100)
  kabupaten_kota         String?                  @db.VarChar(100)
  kecamatan              String?                  @db.VarChar(100)
  desa_kelurahan         String?                  @db.VarChar(100)
  latitude               Decimal?                 @db.Decimal(10, 8)
  longitude              Decimal?                 @db.Decimal(11, 8)
  dim_mustahik           dim_mustahik[]
  fact_aktivitas_ambulan fact_aktivitas_ambulan[]
