  dim_lokasi          dim_lokasi?               @relation(fields: [sk_lokasi], references: [sk_lokasi], onDelete: Restrict, map: "fk_mustahik_lokasi")
  fact_penyaluran     fact_penyaluran[]
  fact_skor_kelayakan fact_skor_kelayakan[]
  fact_survey         fact_survey[]

  @@index([sk_lokasi], map: "fk_mustahik_lokasi")
}

