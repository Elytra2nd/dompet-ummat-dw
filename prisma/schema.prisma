/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model dim_mustahik {
  sk_mustahik         Int                       @id @default(autoincrement())
  id_mustahik         String                    @unique(map: "id_mustahik") @db.VarChar(50)
  nik                 String?                   @db.VarChar(50)
  kk                  String?                   @db.VarChar(50)
  nama                String?                   @db.VarChar(255)
  gender              dim_mustahik_gender?
  no_hp               String?                   @db.VarChar(50)
  kategori_pm         dim_mustahik_kategori_pm? @default(To_Be_Determined)
  alamat              String?                   @db.Text
  desa                String?                   @db.VarChar(100)
  kelurahan_kecamatan String?                   @db.VarChar(100)
  kabupaten_kota      String?                   @db.VarChar(100)
  alasan_dibantu      String?                   @db.Text
  skoring             Decimal?                  @db.Decimal(10, 2)
  jumlah_jiwa         Int?
  valid_from          DateTime?                 @default(dbgenerated("'2018-01-01'")) @db.Date
  valid_to            DateTime?                 @default(dbgenerated("'9999-12-31'")) @db.Date
